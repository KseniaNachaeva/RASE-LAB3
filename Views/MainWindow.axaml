<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RaceSimulator.ViewModels"
        xmlns:views="using:RaceSimulator.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
        x:Class="RaceSimulator.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="F1 Race Simulator"
        Width="920" Height="750"
        MinWidth="720" MinHeight="400"
        Background="#0A0A18">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">

        
        <Border Grid.Row="0" Background="#12122A" Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="8">

                <TextBlock Text="F1 Race Simulator"
                           FontSize="20" FontWeight="Bold"
                           Foreground="#E0E0FF"
                           VerticalAlignment="Center"/>

                <Rectangle Width="1" Fill="#333366" Margin="8,0"/>

                <Button Content="+ Add Race"
                        Command="{Binding AddRaceCommand}"
                        Padding="12,6"
                        Background="#22AA44" Foreground="White"
                        FontWeight="SemiBold"
                        CornerRadius="5"/>

                <Button Content="▶ Start All"
                        Command="{Binding StartAllCommand}"
                        Padding="12,6"
                        Background="#1155AA" Foreground="White"
                        CornerRadius="5"/>

                <Button Content="■ Stop All"
                        Command="{Binding StopAllCommand}"
                        Padding="12,6"
                        Background="#AA3311" Foreground="White"
                        CornerRadius="5"/>

            </StackPanel>
        </Border>

        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Races}" Margin="4">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:RaceViewModel">
                        <views:RaceView Margin="0,4"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</Window>
